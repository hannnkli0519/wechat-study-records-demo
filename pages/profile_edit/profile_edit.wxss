.header {
  padding: 40rpx 40rpx 60rpx;
  background: #fff;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #334155;
}

.edit-form {
  padding: 0 40rpx;
}

.avatar-upload-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 60rpx 0 80rpx;
}

.avatar-wrapper {
  width: 200rpx;
  height: 200rpx;
  border-radius: 100rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
  background: #f1f5f9;
}

.avatar {
  width: 100%;
  height: 100%;
}

.upload-mask {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60rpx;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  justify-content: center;
  align-items: center;
}

.camera-icon {
  font-size: 30rpx;
  color: #fff;
}

.upload-tip {
  font-size: 26rpx;
  color: #94a3b8;
  margin-top: 24rpx;
}

.input-group {
  background: #fff;
  padding: 30rpx 40rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  margin-bottom: 80rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.label {
  font-size: 30rpx;
  color: #334155;
  width: 120rpx;
}

.nickname-input {
  flex: 1;
  font-size: 30rpx;
  color: #1e293b;
}

.save-btn-wrapper {
  margin-top: 100rpx;
}

.save-btn {
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  height: 100rpx;
  border-radius: 50rpx;
  box-shadow: 0 10rpx 40rpx rgba(7, 193, 96, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.save-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}