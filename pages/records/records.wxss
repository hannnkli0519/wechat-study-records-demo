.header {
  padding: 40rpx 30rpx 20rpx;
  background: #fff;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
}

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #fff;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
}

.main-content {
  width: 100%;
  display: block;
}

.calendar-card {
  margin: 20rpx 30rpx;
  padding: 30rpx;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.current-month {
  font-size: 32rpx;
  font-weight: bold;
}

.calendar-nav {
  display: flex;
}

.nav-btn {
  font-size: 40rpx;
  color: #999;
  padding: 0 20rpx;
}

.weekday-header {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  text-align: center;
  margin-bottom: 20rpx;
}

.weekday-header text {
  font-size: 24rpx;
  color: #999;
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  row-gap: 20rpx;
}

.day-slot {
  height: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.day-num {
  font-size: 28rpx;
}

.not-current .day-num {
  color: #eee;
}

.today .day-num {
  color: #fff;
  background: #07c160;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
}

.dot {
  width: 8rpx;
  height: 8rpx;
  background: #07c160;
  border-radius: 50%;
  margin-top: 4rpx;
}

.stats-container {
  display: flex;
  justify-content: space-between;
  margin: 30rpx;
}

.stat-card {
  flex: 1;
  background: #fff;
  padding: 24rpx;
  border-radius: 20rpx;
  margin: 0 10rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.stat-card:first-child { margin-left: 0; }
.stat-card:last-child { margin-right: 0; }

.stat-label {
  font-size: 24rpx;
  margin-bottom: 10rpx;
}

.stat-value {
  display: flex;
  align-items: baseline;
}

.num {
  font-size: 44rpx;
  font-weight: bold;
  margin-right: 4rpx;
}

.unit {
  font-size: 24rpx;
}

.green .stat-label { color: #07c160; }
.green .stat-value { color: #07c160; }
.green { background: #f0fdf4; }

.orange .stat-label { color: #f97316; }
.orange .stat-value { color: #f97316; }
.orange { background: #fff7ed; }

.blue .stat-label { color: #3b82f6; }
.blue .stat-value { color: #3b82f6; }
.blue { background: #eff6ff; }

.history-section {
  margin: 40rpx 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
}

.view-all {
  font-size: 26rpx;
  color: #07c160;
}

.history-item {
  margin-bottom: 40rpx;
  position: relative;
}

.item-line {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.item-dot {
  width: 16rpx;
  height: 16rpx;
  background: #07c160;
  border-radius: 50%;
  margin-right: 20rpx;
  z-index: 1;
}

.item-time {
  font-size: 28rpx;
  font-weight: bold;
  color: #334155;
}

.item-content-box {
  margin-left: 36rpx;
  padding: 24rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  border-left: 4rpx solid #e2e8f0;
}

.item-content {
  font-size: 26rpx;
  line-height: 1.6;
  color: #64748b;
}

/* 连接线 */
.history-item::after {
  content: '';
  position: absolute;
  top: 16rpx;
  left: 7rpx;
  bottom: -40rpx;
  width: 2rpx;
  background: #f1f5f9;
}

.history-item:last-child::after {
  display: none;
}

.footer-space {
  height: 60rpx;
}