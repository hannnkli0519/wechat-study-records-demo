.user-section {
  padding: 60rpx 40rpx;
  background: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar-container {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  overflow: hidden;
  margin-right: 30rpx;
  border: 4rpx solid #f0fdf4;
}

.avatar {
  width: 100%;
  height: 100%;
}

.nickname {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.user-id {
  font-size: 24rpx;
  color: #999;
}

.settings-btn {
  font-size: 40rpx;
  padding: 20rpx;
}

.achievement-card {
  margin: 0 30rpx 40rpx;
  background: #fff;
  border-radius: 30rpx;
  padding: 40rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #334155;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #94a3b8;
  margin-bottom: 4rpx;
}

.stat-unit {
  font-size: 20rpx;
  color: #07c160;
}

.stat-divider {
  width: 1rpx;
  height: 80rpx;
  background: #f1f5f9;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin: 40rpx 40rpx 20rpx;
  color: #334155;
}

.settings-list {
  background: #fff;
  margin: 0 30rpx 30rpx;
  border-radius: 24rpx;
  padding: 0 30rpx;
}

.settings-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.settings-item:last-child {
  border-bottom: none;
}

.item-left {
  display: flex;
  align-items: center;
}

.item-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.item-text {
  font-size: 30rpx;
  color: #334155;
}

.item-right {
  display: flex;
  align-items: center;
}

.item-value {
  font-size: 28rpx;
  color: #64748b;
  margin-right: 10rpx;
}

.arrow {
  font-size: 36rpx;
  color: #cbd5e1;
}