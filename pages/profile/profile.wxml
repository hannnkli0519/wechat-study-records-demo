<view class="container">
  <!-- 用户信息区域 -->
  <view class="user-section">
    <view class="user-info">
      <view class="avatar-container">
        <image class="avatar" src="{{userInfo.avatarUrl || '/images/avatar.png'}}" mode="aspectFill"></image>
      </view>
      <view class="info-text">
        <text class="nickname">{{userInfo.nickname}}</text>
        <text class="user-id">ID: {{userInfo.userId}}</text>
      </view>
    </view>
    <view class="settings-btn" bindtap="goToEdit">
      <text class="settings-icon">⚙️</text>
    </view>
  </view>

  <!-- 成就数据卡片 -->
  <view class="achievement-card">
    <view class="stat-item">
      <view class="stat-value">{{totalPunchInDays}}</view>
      <view class="stat-label">总打卡</view>
      <view class="stat-unit">天</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <view class="stat-value">{{maxContinuousDays}}</view>
      <view class="stat-label">最高连续</view>
      <view class="stat-unit">天</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <view class="stat-value">{{monthlyPunchInDays}}</view>
      <view class="stat-label">本月排名</view>
      <view class="stat-unit">名</view>
    </view>
  </view>

  <!-- 目标管理 -->
  <view class="section-title">目标设置</view>
  <view class="settings-list">
    <view class="settings-item" bindtap="handleDurationChange">
      <view class="item-left">
        <text class="item-icon">🕒</text>
        <text class="item-text">每日学习目标时长</text>
      </view>
      <view class="item-right">
        <text class="item-value">{{studyDuration}} 小时</text>
        <text class="arrow">›</text>
      </view>
    </view>
    <view class="settings-item">
      <view class="item-left">
        <text class="item-icon">🔔</text>
        <text class="item-text">打卡提醒</text>
      </view>
      <view class="item-right">
        <switch checked="{{wakeUpReminder}}" bindchange="handleReminderChange" color="#07c160" />
      </view>
    </view>
  </view>

  <!-- 其他功能列表 -->
  <view class="settings-list">
    <view class="settings-item">
      <view class="item-left">
        <text class="item-icon">🏆</text>
        <text class="item-text">勋章墙</text>
      </view>
      <view class="item-right">
        <text class="arrow">›</text>
      </view>
    </view>
    <view class="settings-item">
      <view class="item-left">
        <text class="item-icon">💬</text>
        <text class="item-text">意见反馈</text>
      </view>
      <view class="item-right">
        <text class="arrow">›</text>
      </view>
    </view>
  </view>
</view>